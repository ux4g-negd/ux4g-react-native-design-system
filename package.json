{
  "name": "ux4g-react-native-design-system",
  "version": "1.0.0",
  "description": "Foundations, design tokens, and theme architecture of the UX4G Design System for React Native and TypeScript.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__/**",
    "!**/*.test.*"
  ],
  "scripts": {
    "build": "bob build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "android": "npm --prefix example run android",
    "example": "npm --prefix example run android"
  },
  "keywords": [
    "react-native",
    "ux4g",
    "design-system",
    "tokens",
    "theme",
    "india-stack",
    "government"
  ],
  "author": "UX4G Team",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0 <0.79.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.86.0",
    "@testing-library/react-native": "^12.6.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.12",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.6",
    "react-native-builder-bob": "^0.43.0",
    "react-native-svg": "^15.15.5",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
